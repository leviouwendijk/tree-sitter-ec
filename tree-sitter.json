{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "ec",
      "camelcase": "EntryCompiler",
      "title": "Entry Compiler",
      "scope": "source.ec",
      "file-types": [
        "ec"
      ],
      "injection-regex": "^ec$",
      "class-name": "TreeSitterEc"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Parser for entry compiler files.",
    "authors": [
      {
        "name": "Levi Ouwendijk",
        "email": "leviouwendijk@gmail.com"
      }
    ],
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-ec"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}